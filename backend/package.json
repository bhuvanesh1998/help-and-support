{
  "name": "@help-assistant/backend",
  "version": "1.0.0",
  "private": true,
  "description": "In-App Tutorial & Help Assistant — backend API (PostgreSQL + Prisma + Express, native ESM).",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.20.0",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^18.0.5",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.2"
  }
}
