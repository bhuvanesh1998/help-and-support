# ── Production environment for the Help Assistant BACKEND ────────────────────
# Set these as environment variables on the Coolify "backend" app (do NOT commit
# a filled-in copy — these are secrets). The frontend is a SEPARATE Coolify app.

NODE_ENV=production
PORT=3000

# Public origin the BACKEND is served from (used for media URLs + the widget
# loader). This is the backend app's own domain — NOT the frontend's.
PUBLIC_BASE_URL=https://your-backend.sslip.io

# Allowed browser origins (comma-separated). Because the SPA is served from a
# DIFFERENT origin, this MUST include the frontend app's domain so cross-origin
# XHR/fetch (login, admin, analytics) is permitted. Add client sites if they
# call the API directly.
CORS_ORIGIN=https://your-frontend.sslip.io

# Origins allowed to FRAME the /embed help panel (space-separated, CSP
# frame-ancestors). '*' = any site may embed the widget; tighten in production.
EMBED_ALLOWED_ORIGINS=*

# Existing PostgreSQL (twixordocs). Keep the value you already use in dev.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5565/twixordocs?schema=public

# Auth — MUST be >= 32 chars in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE-ME-64-PLUS-HEX-CHARS
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Encrypts at-rest secrets (stored API key, MCP token). Defaults to JWT_SECRET
# if unset; set a separate value if you prefer.
# SETTINGS_ENCRYPTION_KEY=

# Uploads — keep ./uploads and mount a persistent volume at /app/backend/uploads.
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Set to "true" ONLY on a fresh/empty database to push the Prisma schema and seed
# the super admin on boot (idempotent). Leave UNSET when reusing an in-sync DB.
# RUN_DB_PUSH=true
