# ── Production environment for the Help Assistant backend ────────────────────
# Set these as environment variables on the Easypanel service (do NOT commit a
# filled-in copy — these are secrets).

NODE_ENV=production
PORT=3000

# Public origin the app is served from (used for media URLs + the widget loader).
# Set to your real domain once assigned, e.g. https://help.twixor.com
PUBLIC_BASE_URL=https://CHANGE-ME

# Allowed browser origins (comma-separated). Include the app's own domain and
# any client sites that call the API. For a same-origin SPA, the app domain alone.
CORS_ORIGIN=https://CHANGE-ME

# Origins allowed to FRAME the /embed help panel (space-separated, CSP
# frame-ancestors). '*' = any site may embed the widget; tighten in production.
EMBED_ALLOWED_ORIGINS=*

# Existing PostgreSQL (same server). Keep the value you already use in dev.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5565/twixordocs?schema=public

# Auth — MUST be >= 32 chars in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE-ME-64-PLUS-HEX-CHARS
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Encrypts at-rest secrets (stored API key, MCP token). Defaults to JWT_SECRET
# if unset; set a separate value if you prefer.
# SETTINGS_ENCRYPTION_KEY=

# Uploads — keep ./uploads and mount a persistent volume there in Easypanel.
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10
